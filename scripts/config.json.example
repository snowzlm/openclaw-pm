{
  "gateway": {
    "port": 18789,
    "logPath": "/tmp/openclaw",
    "healthCheckInterval": 300
  },
  "locks": {
    "timeoutMinutes": 5,
    "forceRemoveMinutes": 15
  },
  "queue": {
    "stuckThresholdMinutes": 3
  },
  "retry": {
    "maxRetries": 5,
    "intervalSeconds": 120
  },
  "cron": {
    "criticalJobs": [
      {
        "name": "example-job",
        "jobId": "00000000-0000-0000-0000-000000000000",
        "description": "示例任务（请修改为实际任务）"
      }
    ]
  },
  "notifications": {
    "enabled": true,
    "channels": ["telegram"]
  },
  "backup": {
    "enabled": true,
    "path": "$HOME/.openclaw/backups"
  }
}
