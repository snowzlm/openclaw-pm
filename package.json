{
  "name": "@snowzlm/openclaw-pm",
  "version": "4.0.0",
  "description": "OpenClaw 项目管理工具 v4.0.0 - TypeScript 重构版",
  "main": "dist/cli.js",
  "bin": {
    "openclaw-pm": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "legacy:setup": "bash scripts/setup.sh",
    "legacy:diagnose": "bash scripts/quick-diagnose.sh",
    "legacy:health": "bash scripts/gateway-health-check.sh",
    "legacy:briefing": "bash scripts/morning-briefing.sh",
    "legacy:stats": "bash scripts/daily-stats.sh"
  },
  "keywords": [
    "openclaw",
    "ai",
    "agent",
    "project-manager",
    "pm",
    "configuration",
    "v4",
    "typescript",
    "cross-platform",
    "health-check",
    "monitoring",
    "task-management",
    "session-isolation",
    "auto-recovery",
    "backup",
    "restore"
  ],
  "author": "snowzlm (based on VA7's work)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snowzlm/openclaw-pm.git"
  },
  "bugs": {
    "url": "https://github.com/snowzlm/openclaw-pm/issues"
  },
  "homepage": "https://github.com/snowzlm/openclaw-pm#readme",
  "files": [
    "dist/",
    "scripts/",
    "docs/",
    "README.md",
    "CHANGELOG-v4.md"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "directories": {
    "doc": "docs"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  }
}
